---
const title = 'Websites for Local Businesses in Palm Beach County, FL | Lambertt Tech';
const description =
  'Custom websites for local businesses across Palm Beach County, FL. Based in Jupiter, serving Jupiter, Palm Beach Gardens, Tequesta, Wellington and beyond. Free mockup included.';
const url = 'https://lambertttech.com/';
const ogImage = 'https://lambertttech.com/og-image.png?v=2';
---

<meta charset='UTF-8' />
<meta
  name='viewport'
  content='width=device-width, initial-scale=1.0'
/>
<title>{title}</title>
<meta
  name='description'
  content={description}
/>
<link
  rel='canonical'
  href={url}
/>
<meta
  name='robots'
  content='index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'
/>
<meta
  name='theme-color'
  content='#0F6BAE'
/>
<link
  rel='manifest'
  href='/manifest.json'
/>
<link
  rel='icon'
  type='image/svg+xml'
  href='/favicon.svg'
/>
<link
  rel='icon'
  type='image/png'
  sizes='32x32'
  href='/favicon-32.png'
/>
<link
  rel='apple-touch-icon'
  sizes='180x180'
  href='/apple-touch-icon.png'
/>
<!-- Open Graph -->
<meta
  property='og:type'
  content='website'
/>
<meta
  property='og:site_name'
  content='Lambertt Tech LLC'
/>
<meta
  property='og:locale'
  content='en_US'
/>
<meta
  property='og:url'
  content={url}
/>
<meta
  property='og:title'
  content={title}
/>
<meta
  property='og:description'
  content={description}
/>
<meta
  property='og:image'
  content={ogImage}
/>
<meta
  property='og:image:secure_url'
  content={ogImage}
/>
<meta
  property='og:image:type'
  content='image/png'
/>
<meta
  property='og:image:width'
  content='1200'
/>
<meta
  property='og:image:height'
  content='630'
/>
<meta
  property='og:image:alt'
  content='Lambertt Tech — Websites for local businesses in Palm Beach County, FL'
/>
<!-- Twitter Card -->
<meta
  name='twitter:card'
  content='summary_large_image'
/>
<meta
  name='twitter:url'
  content={url}
/>
<meta
  name='twitter:domain'
  content='lambertttech.com'
/>
<meta
  name='twitter:title'
  content={title}
/>
<meta
  name='twitter:description'
  content='Custom websites for local businesses across Palm Beach County, FL. Based in Jupiter. Free mockup included.'
/>
<meta
  name='twitter:image'
  content={ogImage}
/>
<meta
  name='twitter:image:alt'
  content='Lambertt Tech — Websites for local businesses in Palm Beach County, FL'
/>
<!-- Structured Data -->
<script type='application/ld+json' is:inline>
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Lambertt Tech LLC",
    "url": "https://lambertttech.com/",
    "telephone": "+15617814836",
    "email": "angel@lambertt.tech",
    "description": "Custom web design for local businesses across Palm Beach County, FL. Based in Jupiter, serving the surrounding area with in-person meetings.",
    "image": "https://lambertttech.com/og-image.png?v=2",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Jupiter",
      "addressRegion": "FL",
      "postalCode": "33458",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 26.9342,
      "longitude": -80.0942
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Palm Beach County" },
      { "@type": "City", "name": "Jupiter" },
      { "@type": "City", "name": "Palm Beach Gardens" },
      { "@type": "City", "name": "Tequesta" },
      { "@type": "City", "name": "Wellington" },
      { "@type": "City", "name": "West Palm Beach" },
      { "@type": "City", "name": "Boca Raton" },
      { "@type": "City", "name": "Delray Beach" }
    ],
    "serviceType": "Web Design and Development",
    "priceRange": "$$",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Web Design Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "One-page websites" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website refreshes" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Click-to-call and directions" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Booking integrations" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Photo and content cleanup" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Local SEO basics" } }
      ]
    }
  }
</script>
<link
  rel='dns-prefetch'
  href='https://images.pexels.com'
/>
<link
  rel='preconnect'
  href='https://fonts.googleapis.com'
/>
<link
  rel='preconnect'
  href='https://fonts.gstatic.com'
  crossorigin
/>
<link
  href='https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap'
  rel='stylesheet'
/>
