---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import dldScreenshot from '../../assets/work/digital-lifestyle-designs.png';
import { ico } from '../../lib/icons';

type Example = {
  /** true = real shipped client site, false = concept mockup */
  live: boolean;
  /** Industry / business type — shown as eyebrow text */
  type: string;
  /** Domain shown in the browser chrome bar */
  slug: string;
  /** Live site URL (required when live=true) */
  href?: string;
  /** Headline benefit copy */
  benefit: string;
  /** Up to 3 short capability/stack tags */
  tags: string[];
  /** Local import (ImageMetadata) for shipped sites, or remote URL string for concepts */
  imageSrc: ImageMetadata | string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  /** "top" for site screenshots (show header), "cover" for stock photos. Defaults to cover. */
  imageFit?: 'top' | 'cover';
};

const examples: Example[] = [
  {
    live: true,
    type: 'Smart Home',
    slug: 'digitallifestyledesigns.com',
    href: 'https://www.digitallifestyledesigns.com',
    benefit: 'Multi-page marketing site with full service catalog and contact flow.',
    tags: ['Next.js', 'Tailwind', 'Multi-page'],
    imageSrc: dldScreenshot,
    imageAlt: 'Digital Lifestyle Designs — smart home technology website',
    imageWidth: 1280,
    imageHeight: 900,
    imageFit: 'top',
  },
  {
    live: false,
    type: 'Nail Salon',
    slug: 'nailsalon.com',
    benefit: 'Turns browsers into booked appointments.',
    tags: ['Booking', 'Gallery', 'Click-to-call'],
    imageSrc:
      'https://images.pexels.com/photos/3997390/pexels-photo-3997390.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop',
    imageAlt: 'Polished nail salon interior with neutral palette',
    imageWidth: 960,
    imageHeight: 600,
  },
  {
    live: false,
    type: 'Café & Restaurant',
    slug: 'coastalcafe.com',
    benefit: 'Menu front and center — with hours and ordering.',
    tags: ['Menu', 'Online ordering', 'Google Maps'],
    imageSrc:
      'https://images.pexels.com/photos/1813504/pexels-photo-1813504.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop',
    imageAlt: 'Warmly lit café with wood tables and ambient light',
    imageWidth: 960,
    imageHeight: 600,
  },
  {
    live: false,
    type: 'Local Boutique',
    slug: 'shopboutique.com',
    benefit: 'A lookbook experience that drives walk-ins and DMs.',
    tags: ['Lookbook', 'Instagram', 'Contact form'],
    imageSrc:
      'https://images.pexels.com/photos/3965545/pexels-photo-3965545.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop',
    imageAlt: 'Curated boutique clothing rack with neutral tones',
    imageWidth: 960,
    imageHeight: 600,
  },
];

const hasLive = examples.some(e => e.live);
const hasConcept = examples.some(e => !e.live);
---

<section
  id='work'
  class='px-5 sm:px-8 py-20 md:py-28'
  style='background-color: var(--color-background);'
  aria-labelledby='work-heading'
>
  <div class='mx-auto max-w-6xl'>
    <div class='flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between'>
      <div class='max-w-xl'>
        <p
          class='text-xs font-bold tracking-widest uppercase'
          style='color: var(--color-brand-blue);'
        >
          Work &amp; Examples
        </p>
        <h2
          id='work-heading'
          class='mt-3 text-3xl font-bold tracking-tight sm:text-4xl'
          style='color: var(--color-brand-dark);'
        >
          What your site could look like
        </h2>
        <p
          class='mt-3 text-base leading-relaxed'
          style='color: var(--color-text-secondary);'
        >
          {
            hasLive &&
              hasConcept &&
              "Real client sites I've shipped, alongside concept layouts for businesses like yours. "
          }
          {hasLive && !hasConcept && "Real client sites I've shipped for local businesses. "}
          {!hasLive && hasConcept && 'Concept layouts for the kinds of local businesses I work with. '}
          Every site is built from scratch — not from a template.
        </p>
      </div>
      <a
        href='#contact'
        class='shrink-0 inline-flex items-center gap-2 rounded-full border px-6 py-2.5 text-sm font-semibold transition-all duration-200 hover:-translate-y-px min-h-[44px]'
        style='border-color: var(--color-border); color: var(--color-brand-dark); background-color: var(--color-surface);'
      >
        Get your free mockup <span set:html={ico('arrow-right')} />
      </a>
    </div>

    <div class='mt-12 grid gap-6 sm:grid-cols-2'>
      {
        examples.map(ex => {
          const Wrapper = ex.live ? 'a' : 'div';
          const wrapperProps = ex.live
            ? {
                href: ex.href!,
                target: '_blank',
                rel: 'noopener noreferrer',
                'aria-label': `View live site: ${ex.slug}`,
              }
            : {};
          return (
            <Wrapper
              class={`group relative block overflow-hidden rounded-3xl border transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${ex.live ? 'cursor-pointer' : ''}`}
              style='border-color: var(--color-border); background-color: var(--color-surface); box-shadow: 0 2px 8px 0 rgba(var(--color-black-rgb),0.05);'
              {...wrapperProps}
            >
              <div
                class='absolute top-0 left-0 right-0 h-0.5 opacity-0 transition-opacity duration-300 group-hover:opacity-100'
                style='background-color: var(--color-brand-blue);'
              />
              <div
                class='flex items-center gap-2.5 border-b px-4 py-2.5'
                style='background-color: var(--color-cool-gray-100); border-color: var(--color-border);'
              >
                <div
                  class='flex gap-1.5 shrink-0'
                  aria-hidden='true'
                >
                  <div
                    class='h-2.5 w-2.5 rounded-full'
                    style='background-color: var(--color-mac-red);'
                  />
                  <div
                    class='h-2.5 w-2.5 rounded-full'
                    style='background-color: var(--color-mac-amber);'
                  />
                  <div
                    class='h-2.5 w-2.5 rounded-full'
                    style='background-color: var(--color-mac-green);'
                  />
                </div>
                <div
                  class='flex flex-1 items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px]'
                  style='background-color: var(--color-surface); color: var(--color-text-secondary); border: 1px solid var(--color-border);'
                >
                  <div
                    class='h-1.5 w-1.5 rounded-full shrink-0'
                    style='background-color: var(--color-accent-teal);'
                  />
                  {ex.slug}
                </div>
              </div>
              <div
                class='relative overflow-hidden'
                style='height: 220px;'
              >
                <Image
                  src={ex.imageSrc}
                  alt={ex.imageAlt}
                  width={ex.imageWidth}
                  height={ex.imageHeight}
                  class={`h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05] ${ex.imageFit === 'top' ? 'object-top' : ''}`}
                  loading='lazy'
                />
                {ex.live && (
                  <span
                    class='absolute top-3 right-3 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold'
                    style='background-color: rgba(var(--color-white-rgb),0.96); color: var(--color-accent-teal); box-shadow: 0 2px 8px rgba(var(--color-navy-rgb),0.15); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);'
                  >
                    <span class='relative flex h-1.5 w-1.5'>
                      <span
                        class='absolute inline-flex h-full w-full rounded-full opacity-60 animate-ping'
                        style='background-color: var(--color-accent-teal);'
                      />
                      <span
                        class='relative inline-flex h-1.5 w-1.5 rounded-full'
                        style='background-color: var(--color-accent-teal);'
                      />
                    </span>
                    Live
                  </span>
                )}
                <div
                  class='absolute inset-x-0 bottom-0 h-20'
                  style='background: linear-gradient(to top, rgba(var(--color-surface-rgb),0.95) 0%, transparent 100%);'
                  aria-hidden='true'
                />
              </div>
              <div class='px-5 pb-5 pt-1'>
                <div class='flex items-start justify-between gap-3'>
                  <div class='min-w-0'>
                    <p
                      class='text-[11px] font-bold tracking-widest uppercase'
                      style='color: var(--color-brand-blue);'
                    >
                      {ex.type}
                    </p>
                    <p
                      class='mt-1 text-base font-semibold leading-snug'
                      style='color: var(--color-brand-dark);'
                    >
                      {ex.benefit}
                    </p>
                  </div>
                  <span
                    class='shrink-0 mt-0.5 inline-flex items-center gap-1 text-[11px] font-semibold px-3 py-1 rounded-full'
                    style={
                      ex.live
                        ? 'background-color: var(--color-brand-soft); color: var(--color-brand-blue); border: 1px solid rgba(var(--color-blue-rgb),0.18);'
                        : 'background-color: var(--color-cool-gray-100); color: var(--color-text-secondary); border:1px solid var(--color-border);'
                    }
                  >
                    {ex.live ? (
                      <>
                        Visit
                        <span set:html={ico('arrow-right')} />
                      </>
                    ) : (
                      'Concept'
                    )}
                  </span>
                </div>
                <div class='mt-4 flex flex-wrap gap-2'>
                  {ex.tags.map(t => (
                    <span
                      class='inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold'
                      style='background-color: var(--color-brand-soft); color: var(--color-brand-blue);'
                    >
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </Wrapper>
          );
        })
      }
    </div>

    {
      hasConcept && (
        <p
          class='mt-8 text-sm text-center'
          style='color: var(--color-text-secondary);'
        >
          These are concept layouts. Your site is designed specifically for your business.
        </p>
      )
    }
  </div>
</section>
