---
import { Image } from 'astro:assets';
import jupiterLighthouse from '../../assets/lightouse-sunset.jpg';
import { email, phone, phoneHref } from '../../lib/contact';
import { ico } from '../../lib/icons';
---

<section
  id='contact'
  class='px-5 pb-24 sm:px-8 lg:px-10'
  style='background-color: var(--color-background);'
>
  <div
    class='mx-auto max-w-6xl overflow-hidden rounded-[36px] shadow-2xl'
    style='background-color: var(--color-navy); isolation: isolate; -webkit-mask-image: -webkit-radial-gradient(white, black); transform: translateZ(0);'
  >
    <div class='grid lg:grid-cols-[1.1fr_0.9fr]'>
      <!-- Left: CTA copy -->
      <div class='relative p-8 sm:p-10 lg:p-12 overflow-hidden'>
        <Image
          src={jupiterLighthouse}
          alt=''
          aria-hidden='true'
          widths={[800, 1200, 1600]}
          sizes='(min-width: 1024px) 720px, 100vw'
          class='absolute inset-0 h-full w-full object-cover opacity-60'
          style='object-position: 50% 10%;'
          loading='lazy'
        />
        <div
          class='absolute inset-0'
          style='background: linear-gradient(90deg, rgba(var(--color-navy-rgb),0.95) 0%, rgba(var(--color-navy-rgb),0.78) 45%, rgba(var(--color-navy-rgb),0.35) 100%);'
          aria-hidden='true'
        >
        </div>
        <div
          class='pointer-events-none absolute -left-20 -top-20 h-64 w-64 rounded-full'
          style='background-color: rgba(var(--color-blue-bright-rgb),0.20); filter: blur(60px);'
          aria-hidden='true'
        >
        </div>
        <div class='relative'>
          <p
            class='mb-3 text-[11px] font-bold uppercase tracking-[0.24em]'
            style='color: var(--color-sky-300);'
          >
            Get in touch
          </p>
          <h2 class='max-w-xl text-4xl font-bold tracking-[-0.055em] text-white sm:text-5xl'>
            Want to see what your site could look like?
          </h2>
          <p
            class='mt-5 max-w-2xl text-base leading-7'
            style='color: var(--color-slate-300);'
          >
            Send your business name, website if you have one, and a few examples you like. I'll put together a free
            one-page mockup so you can decide before moving forward.
          </p>
          <div class='mt-8 flex flex-col gap-3 sm:flex-row'>
            <a
              href={`mailto:${email}`}
              class='inline-flex min-h-14 items-center justify-center rounded-full px-8 text-sm font-bold transition-all duration-200 hover:-translate-y-0.5'
              style='background-color: var(--color-blue-bright); color: var(--color-navy); box-shadow: 0 10px 24px -8px rgba(var(--color-blue-bright-rgb),0.4);'
            >
              Get a free mockup <span
                class='ml-2'
                set:html={ico('arrow-right')}
              />
            </a>
            <a
              href={phoneHref}
              class='inline-flex min-h-14 items-center justify-center rounded-full border border-white/20 bg-white/5 px-8 text-sm font-bold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-white/10'
            >
              Call me <span
                class='ml-2'
                set:html={ico('phone')}
              />
            </a>
          </div>
          <p
            class='mt-5 text-sm'
            style='color: var(--color-slate-400);'
          >
            Free mockup. No obligation. No sales pitch.
          </p>
        </div>
      </div>

      <!-- Right: contact details -->
      <div class='border-t border-white/10 bg-white/[0.04] p-8 sm:p-10 lg:border-l lg:border-t-0 lg:p-12'>
        <div class='space-y-5'>
          <a
            href={phoneHref}
            class='flex items-center gap-4 rounded-3xl border border-white/10 bg-white/[0.05] p-4 transition hover:bg-white/[0.08]'
          >
            <span
              class='grid h-11 w-11 place-items-center rounded-full'
              style='background-color: rgba(var(--color-blue-bright-rgb),0.15); color: var(--color-blue-bright);'
              set:html={ico('phone')}
            />
            <span>
              <span class='block text-sm font-semibold text-white'>{phone}</span>
              <span
                class='text-sm'
                style='color: var(--color-slate-400);'
                >Call or text anytime</span
              >
            </span>
          </a>

          <a
            href={`mailto:${email}`}
            class='flex items-center gap-4 rounded-3xl border border-white/10 bg-white/[0.05] p-4 transition hover:bg-white/[0.08]'
          >
            <span
              class='grid h-11 w-11 place-items-center rounded-full'
              style='background-color: rgba(var(--color-blue-bright-rgb),0.15); color: var(--color-blue-bright);'
              set:html={ico('mail')}
            />
            <span>
              <span class='block text-sm font-semibold text-white'>{email}</span>
              <span
                class='text-sm'
                style='color: var(--color-slate-400);'
                >I usually reply the same day</span
              >
            </span>
          </a>

          <div class='flex items-center gap-4 rounded-3xl border border-white/10 bg-white/[0.05] p-4'>
            <span
              class='grid h-11 w-11 place-items-center rounded-full'
              style='background-color: rgba(var(--color-blue-bright-rgb),0.15); color: var(--color-blue-bright);'
              set:html={ico('map-pin')}
            />
            <span>
              <span class='block text-sm font-semibold text-white'>Jupiter, Florida</span>
              <span
                class='text-sm'
                style='color: var(--color-slate-400);'
                >Serving Palm Beach County</span
              >
            </span>
          </div>
        </div>

        <div
          class='mt-8 rounded-3xl border p-5'
          style='border-color: rgba(var(--color-blue-bright-rgb),0.20); background-color: rgba(var(--color-blue-bright-rgb),0.10);'
        >
          <div class='flex gap-3'>
            <span
              class='mt-0.5 shrink-0'
              style='color: var(--color-blue-bright);'
              set:html={ico('sparkles')}
            />
            <p
              class='text-sm leading-6'
              style='color: var(--color-slate-300);'
            >
              The first mockup is meant to make the decision easier. You will see the direction before approving the
              project.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
