---
const navLinks = [
  { href: '#work', label: 'Examples' },
  { href: '#services', label: 'Services' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  class='sticky top-0 z-40 w-full border-b'
  style='background-color: rgba(var(--color-surface-rgb),0.88); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-color: var(--color-border);'
>
  <div class='mx-auto max-w-6xl px-5 sm:px-8'>
    <div class='flex h-[80px] items-center justify-between gap-8'>
      <a
        href='#'
        class='flex items-center shrink-0'
        aria-label='Lambertt Tech — home'
      >
        <img
          src='/brand/logo-horizontal.svg'
          alt='Lambertt Tech'
          width='224'
          height='56'
          class='logo-light block h-[56px] w-auto'
        />
        <img
          src='/brand/logo-horizontal-dark.png'
          alt='Lambertt Tech'
          width='224'
          height='56'
          class='logo-dark block h-[56px] w-auto'
        />
      </a>

      <nav
        class='hidden md:flex items-center gap-8'
        aria-label='Main navigation'
      >
        {
          navLinks.map(link => (
            <a
              href={link.href}
              class='text-sm font-medium leading-none tracking-wide transition-opacity hover:opacity-70'
              style='color: var(--color-text-secondary);'
            >
              {link.label}
            </a>
          ))
        }
        <button
          type='button'
          id='theme-toggle'
          class='inline-flex h-9 w-9 items-center justify-center rounded-full transition-colors'
          style='color: var(--color-text-secondary);'
          aria-label='Switch to dark theme'
        >
          <svg
            class='theme-icon-sun'
            width='18'
            height='18'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            ><circle cx='12' cy='12' r='4'></circle><path
              d='M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41'
            ></path></svg
          >
          <svg
            class='theme-icon-moon'
            width='18'
            height='18'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            ><path d='M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z'></path></svg
          >
        </button>
        <a
          href='#contact'
          class='inline-flex items-center rounded-full px-5 py-2.5 text-sm font-semibold leading-none text-white transition-all duration-200 hover:-translate-y-px hover:shadow-md active:translate-y-0'
          style='background-color: var(--color-brand-blue); letter-spacing: 0.01em; box-shadow: 0 1px 6px 0 rgba(var(--color-blue-rgb),0.22);'
          >Get a free mockup</a
        >
      </nav>

      <!-- Mobile hamburger (CSS-only toggle) -->
      <div class='md:hidden relative'>
        <input
          type='checkbox'
          id='nav-toggle'
          class='sr-only'
          aria-label='Toggle mobile menu'
        />
        <label
          for='nav-toggle'
          class='flex h-11 w-11 cursor-pointer items-center justify-center rounded-full'
          style='color: var(--color-text-primary);'
          aria-label='Open navigation menu'
        >
          <svg
            class='hamburger-open'
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            aria-hidden='true'
            ><path
              d='M3 5h14M3 10h14M3 15h14'
              stroke='currentColor'
              stroke-width='1.75'
              stroke-linecap='round'
            ></path></svg
          >
          <svg
            class='hamburger-close'
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            aria-hidden='true'
            ><path
              d='M5 5l10 10M15 5L5 15'
              stroke='currentColor'
              stroke-width='1.75'
              stroke-linecap='round'
            ></path></svg
          >
        </label>
        <div
          class='mobile-menu absolute right-0 mt-2 w-64 rounded-2xl border shadow-xl p-4'
          style='background-color: var(--color-surface); border-color: var(--color-border);'
        >
          <nav
            class='flex flex-col gap-1'
            aria-label='Mobile navigation'
          >
            <button
              type='button'
              id='theme-toggle-mobile'
              class='flex items-center justify-between w-full py-2.5 text-sm font-medium'
              style='color: var(--color-text-secondary);'
              aria-label='Switch to dark theme'
            >
              <span class='theme-toggle-label-sun'>Light theme</span>
              <span class='theme-toggle-label-moon'>Dark theme</span>
              <span class='inline-flex h-7 w-7 items-center justify-center'>
                <svg
                  class='theme-icon-sun'
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                  ><circle cx='12' cy='12' r='4'></circle><path
                    d='M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41'
                  ></path></svg
                >
                <svg
                  class='theme-icon-moon'
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                  ><path d='M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z'
                  ></path></svg
                >
              </span>
            </button>
            {
              navLinks.map(link => (
                <a
                  href={link.href}
                  class='py-2.5 text-sm font-medium'
                  style='color: var(--color-text-secondary);'
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href='#contact'
              class='mt-3 inline-flex items-center justify-center rounded-full px-7 text-sm font-semibold text-white min-h-[48px]'
              style='background-color: var(--color-brand-blue); box-shadow: 0 2px 12px 0 rgba(var(--color-blue-rgb),0.22);'
              >Get a free mockup</a
            >
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>
