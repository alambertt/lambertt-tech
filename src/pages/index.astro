---
import "../styles/global.css";

const phone = "(561) 555‑0000";
const phoneHref = "tel:+15615550000";
const email = "angel@lambertt.tech";

type Example = {
  name: string;
  category: string;
  url: string;
  liveHref: string;
  mockStyle: string;
  logoBg?: string;
  chromeStyle?: string;
  urlStyle?: string;
  navStyle?: string;
  headline: string;
  headlineStyle?: string;
  sub: string;
  subStyle?: string;
  pillText: string;
  pillStyle?: string;
  thumbStyle?: string;
};

const examples: Example[] = [
  {
    name: "Coastal Nails",
    category: "Nail salon · Jupiter, FL",
    url: "coastalnailsjupiter.com",
    liveHref: "#",
    mockStyle: "--mock-bg:#F7E9E1; --mock-pill:#C25437; --mock-thumb:#EFD2C2;",
    headline: "Hands and feet,<br/>cared for.",
    sub: "Walk-ins welcome, weekends booked solid.",
    pillText: "Book on Square →",
  },
  {
    name: "Harbor Coffee",
    category: "Café · Tequesta, FL",
    url: "harbor-coffee.co",
    liveHref: "#",
    mockStyle:
      "--mock-bg:#1F2A24; --mock-pill:#D6A26B; --mock-ink:#F5EDE0; --mock-ink-2:#B7A88F; --mock-thumb:#2E3C34;",
    chromeStyle: "background: rgba(255,255,255,.08);",
    urlStyle: "background:rgba(255,255,255,.1); color:#B7A88F;",
    logoBg: "background:#D6A26B;",
    navStyle: "color:#B7A88F;",
    headline: "Cortados,<br/>and a view.",
    headlineStyle: "color:#F5EDE0;",
    sub: "Open 6:30am · 102 Bridge Rd",
    subStyle: "color:#B7A88F;",
    pillText: "Order ahead",
    pillStyle: "background:#D6A26B; color:#1F2A24;",
    thumbStyle: "background:#2E3C34;",
  },
  {
    name: "Marlin Barbers",
    category: "Barbershop · Jupiter, FL",
    url: "marlin-barbers.com",
    liveHref: "#",
    mockStyle: "--mock-bg:#F4F1EC; --mock-pill:#1A1714; --mock-thumb:#E3DDD2;",
    logoBg: "background:#1A1714;",
    headline: "A proper cut,<br/>since '09.",
    sub: "Three chairs. No appointments before noon.",
    pillText: "(561) 222-0000",
  },
  {
    name: "Olivette",
    category: "Restaurant · Jupiter, FL",
    url: "olivettetable.com",
    liveHref: "#",
    mockStyle: "--mock-bg:#F2EDE3; --mock-pill:#3D5A3A; --mock-thumb:#DCD2BD;",
    logoBg: "background:#3D5A3A;",
    headline: "Italian, on Pennock Lane.",
    headlineStyle: "font-family: 'Geist', serif;",
    sub: "Dinner Tues–Sat · Reservations recommended.",
    pillText: "Book on OpenTable",
    pillStyle: "background:#3D5A3A;",
  },
  {
    name: "June & Vine",
    category: "Boutique · Palm Beach Gardens, FL",
    url: "junevineboutique.com",
    liveHref: "#",
    mockStyle: "--mock-bg:#EFE6E9; --mock-pill:#8E4A6A; --mock-thumb:#E2D2D8;",
    logoBg: "background:#8E4A6A;",
    headline: "New arrivals,<br/>every Friday.",
    sub: "Linen, denim, and the occasional good hat.",
    pillText: "Shop the look",
    pillStyle: "background:#8E4A6A;",
  },
  {
    name: "Tide & Tree Yoga",
    category: "Studio · Jupiter, FL",
    url: "tideandtreeyoga.com",
    liveHref: "#",
    mockStyle: "--mock-bg:#E9EEEC; --mock-pill:#2F6E64; --mock-thumb:#D4DEDB;",
    logoBg: "background:#2F6E64;",
    headline: "A class for any morning.",
    sub: "Drop-ins welcome · First class is on me.",
    pillText: "Book on Setmore",
    pillStyle: "background:#2F6E64;",
  },
];

const services = [
  {
    title: "One-page websites for local businesses.",
    body: "A clean homepage with your hours, location, photos, and a way to get in touch. Usually all you need.",
  },
  {
    title: "Refreshes of sites that look dated.",
    body: "If your site is hard to read on a phone, or hasn't been touched since 2017, I can rebuild it from what you have.",
  },
  {
    title: "Click-to-call and directions setup.",
    body: "Tapping your phone number should call you. Tapping your address should open Maps. Sounds obvious; often broken.",
  },
  {
    title: "Booking integrations.",
    body: "Setmore, Square Appointments, OpenTable, Calendly. I wire them into the page so customers can book without leaving.",
  },
  {
    title: "Photo and content cleanup.",
    body: "I'll crop, compress, and color-correct what you have. If you need new photos, I'll point you to someone local.",
  },
  {
    title: "Local SEO basics.",
    body: "Google Business Profile, meta tags, schema, sitemap. The stuff that helps people in Jupiter actually find you.",
  },
];

const initials = (name: string) => name.replace(/[^A-Za-z]/g, "").charAt(0).toUpperCase();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lambertt Tech LLC — Simple websites for local businesses in Jupiter, FL</title>
    <meta
      name="description"
      content="I build simple, fast websites for salons, restaurants, and shops in Jupiter, Florida. Free one-page mockup before you decide."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar">
      <div class="wrap topbar-inner">
        <div class="brand">
          <span class="brand-mark" aria-hidden="true">L</span>
          <span class="brand-name">
            Lambertt Tech <span class="llc">LLC</span>
          </span>
        </div>
        <nav class="topbar-contact" aria-label="Contact">
          <a href={phoneHref}><span class="dot" aria-hidden="true"></span>{phone}</a>
          <a href={`mailto:${email}`}>{email}</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="wrap">
          <h1>
            Simple websites for <span class="accent">local businesses</span> in Jupiter, FL.
          </h1>
          <p class="lede">
            I'm Angel. I build straightforward, fast websites for salons, restaurants, and shops nearby — the kind that look good on a phone and bring in actual calls and bookings.
          </p>
          <div class="hero-ctas">
            <a class="btn btn-primary" href="#contact">
              Get a free mockup <span class="arr" aria-hidden="true">→</span>
            </a>
            <a class="btn btn-ghost" href="#work">See examples</a>
          </div>
          <div class="hero-meta">
            <a href={phoneHref}>{phone}</a>
            <span class="sep">·</span>
            <a href={`mailto:${email}`}>{email}</a>
            <span class="sep">·</span>
            <span>Based in Jupiter, FL</span>
          </div>
        </div>
      </section>

      <!-- Examples -->
      <section class="section" id="work">
        <div class="wrap">
          <span class="eyebrow">Recent work</span>
          <h2>A few sites I&rsquo;ve built for local shops.</h2>
          <p class="sub">Each one took about two weeks. Click a tile to see the live site.</p>

          <div class="grid">
            {examples.map((ex) => (
              <article class="tile">
                <div class="mock" style={ex.mockStyle}>
                  <span class="placeholder-tag">Placeholder</span>
                  <div class="mock-chrome" style={ex.chromeStyle}>
                    <span class="mock-dot"></span>
                    <span class="mock-dot"></span>
                    <span class="mock-dot"></span>
                    <span class="mock-url" style={ex.urlStyle}>{ex.url}</span>
                  </div>
                  <div class="mock-body">
                    <div class="m-nav">
                      <span class="m-logo" style={ex.logoBg}>{initials(ex.name)}</span>
                      <span style={ex.navStyle}>{ex.name.toUpperCase()}</span>
                    </div>
                    <div style="height:8px"></div>
                    <h3 class="m-h1" style={ex.headlineStyle} set:html={ex.headline}></h3>
                    <p class="m-sub" style={ex.subStyle}>{ex.sub}</p>
                    <span class="m-pill" style={ex.pillStyle}>{ex.pillText}</span>
                    <div class="m-thumbs">
                      <div class="m-thumb" style={ex.thumbStyle}></div>
                      <div class="m-thumb" style={ex.thumbStyle}></div>
                      <div class="m-thumb" style={ex.thumbStyle}></div>
                    </div>
                  </div>
                </div>
                <div class="tile-meta">
                  <div>
                    <h3>{ex.name}</h3>
                    <p>{ex.category}</p>
                  </div>
                  <a class="tile-link" href={ex.liveHref}>View live <span class="arr">→</span></a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- What I do -->
      <section class="section">
        <div class="wrap">
          <span class="eyebrow">What I do</span>
          <h2>Plain-English services, no buzzwords.</h2>
          <p class="sub">
            Most projects are a mix of these. Tell me what you have, and I'll tell you what's actually worth doing.
          </p>

          <div class="services">
            {services.map((svc, i) => (
              <div class="svc">
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h4>{svc.title}</h4>
                  <p>{svc.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Pricing + contact -->
      <section class="section" id="contact">
        <div class="wrap">
          <div class="price-band">
            <div>
              <span class="eyebrow">Pricing &amp; contact</span>
              <h2>What it costs, and how to start.</h2>
              <p class="intro">
                I'll put together a free one-page mockup so you can see what your site would look like before deciding anything. No deposit, no contract until you're in.
              </p>

              <div class="price-card">
                <div class="label">One-page sites</div>
                <div class="range">$800 – $1,800</div>
                <div class="note">
                  Most local businesses land here. Includes hosting setup, domain, basic SEO.
                </div>
              </div>
              <div class="price-card">
                <div class="label">Refreshes &amp; multi-page</div>
                <div class="range">$1,800 – $3,500</div>
                <div class="note">
                  Rebuilds, online menus, booking flows, photo galleries.
                </div>
              </div>
              <p class="footnote">Happy to meet in person if you're in or near Jupiter, FL.</p>
            </div>

            <aside class="contact-card" aria-label="Contact details">
              <div class="contact-row">
                <div class="contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div class="contact-info">
                  <div class="k">Call or text</div>
                  <div class="v"><a href={phoneHref}>{phone}</a></div>
                </div>
              </div>
              <div class="contact-row">
                <div class="contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div class="contact-info">
                  <div class="k">Email</div>
                  <div class="v"><a href={`mailto:${email}`}>{email}</a></div>
                </div>
              </div>
              <div class="contact-row">
                <div class="contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div class="contact-info">
                  <div class="k">Based in</div>
                  <div class="v">Jupiter, Florida</div>
                </div>
              </div>
              <a class="contact-cta" href={`mailto:${email}?subject=Free%20mockup%20request`}>
                Get a free mockup <span aria-hidden="true">→</span>
              </a>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap foot">
        <div class="left">
          <span class="brand-mark" aria-hidden="true">L</span>
          <span>Lambertt Tech LLC · &copy; {new Date().getFullYear()}</span>
        </div>
        <a href="https://alambertt.dev" target="_blank" rel="noopener">
          Engineering portfolio <span class="arr">→</span>
        </a>
      </div>
    </footer>
  </body>
</html>
