  clock: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  "badge-dollar": `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>`,
  sparkles: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>`,
};

const ico = (key: string) => ICONS[key] ?? "";

type Example = {
  /** true = real shipped client site, false = concept mockup */
  live: boolean;
  /** Industry / business type — shown as eyebrow text */
  type: string;
  /** Domain shown in the browser chrome bar */
  slug: string;
  /** Live site URL (required when live=true) */
  href?: string;
  /** Headline benefit copy */
  benefit: string;
  /** Up to 3 short capability/stack tags */
  tags: string[];
  /** Local import (ImageMetadata) for shipped sites, or remote URL string for concepts */
  imageSrc: ImageMetadata | string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  /** "top" for site screenshots (show header), "cover" for stock photos. Defaults to cover. */
  imageFit?: "top" | "cover";
};

const examples: Example[] = [
  {
    live: true,
    type: "Smart Home",
    slug: "digitallifestyledesigns.com",
    href: "https://www.digitallifestyledesigns.com",
    benefit: "Multi-page marketing site with full service catalog and contact flow.",
    tags: ["Next.js", "Tailwind", "Multi-page"],
    imageSrc: dldScreenshot,
    imageAlt: "Digital Lifestyle Designs — smart home technology website",
    imageWidth: 1280,
    imageHeight: 900,
    imageFit: "top",
  },
  {
    live: false,
    type: "Nail Salon",
    slug: "nailsalon.com",
    benefit: "Turns browsers into booked appointments.",
    tags: ["Booking", "Gallery", "Click-to-call"],
    imageSrc:
      "https://images.pexels.com/photos/3997390/pexels-photo-3997390.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop",
    imageAlt: "Polished nail salon interior with neutral palette",
    imageWidth: 960,
    imageHeight: 600,
  },
  {
    live: false,
    type: "Café & Restaurant",
    slug: "coastalcafe.com",
    benefit: "Menu front and center — with hours and ordering.",
    tags: ["Menu", "Online ordering", "Google Maps"],
    imageSrc:
      "https://images.pexels.com/photos/1813504/pexels-photo-1813504.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop",
    imageAlt: "Warmly lit café with wood tables and ambient light",
    imageWidth: 960,
    imageHeight: 600,
  },
  {
    live: false,
    type: "Local Boutique",
    slug: "shopboutique.com",
    benefit: "A lookbook experience that drives walk-ins and DMs.",
    tags: ["Lookbook", "Instagram", "Contact form"],
    imageSrc:
      "https://images.pexels.com/photos/3965545/pexels-photo-3965545.jpeg?auto=compress&cs=tinysrgb&w=960&h=600&fit=crop",
    imageAlt: "Curated boutique clothing rack with neutral tones",
    imageWidth: 960,
    imageHeight: 600,
  },
];

const hasLive = examples.some((e) => e.live);
const hasConcept = examples.some((e) => !e.live);

const services = [
  {
    icon: "monitor",
    title: "One-page websites",
    detail:
      "A single page with everything a customer needs — your services, photos, hours, and a way to reach you. Fast to load, easy to update.",
    note: "Most local businesses only need this.",
  },
  {
    icon: "refresh",
    title: "Website refreshes",
    detail:
      "If your current site is outdated, hard to use on a phone, or just doesn't represent you well anymore — I can rebuild it properly.",
  },
  {
    icon: "phone-l",
    title: "Click-to-call & directions",
    detail:
      "A phone number that dials when tapped, and an address that opens in Google Maps. Small things your customers expect to just work.",
  },
  {
    icon: "calendar",
    title: "Booking integrations",
    detail:
      "I connect your site to whatever scheduling tool you already use — Setmore, Square, OpenTable, Vagaro. You keep your workflow, customers can book directly.",
  },
  {
    icon: "camera",
    title: "Photo & content cleanup",
    detail:
      "Good photos and clear writing make a bigger difference than design. I'll organize your images, cut the fluff, and make sure everything reads well on a small screen.",
  },
  {
    icon: "search-l",
    title: "Local SEO basics",
    detail:
      "Page titles, meta descriptions, structured data, and Google Business setup — the fundamentals that help nearby customers find you when they search.",
  },
];

const steps = [
  {
    num: "01",
    icon: "file-text",
    title: "Send the basics",
    copy: "Share your business name, what you offer, your current site if you have one, and a few examples you like.",
  },
  {
    num: "02",
    icon: "palette",
    title: "I create a free mockup",
    copy: "You get a real one-page design direction so you can see the look and structure before spending anything.",
  },
  {
    num: "03",
    icon: "pointer",
    title: "You decide what happens next",
    copy: "If it feels right, we build it. If not, there is no obligation and no pressure to keep going.",
  },
];

const factors = [
  "Number of pages",
  "Booking integration",
  "Photo cleanup",
  "Service or menu list",
  "Local SEO basics",
  "Existing site refresh",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Websites for Local Businesses in Jupiter, FL | Lambertt Tech</title>
    <meta name="description" content="Custom websites for local businesses in Jupiter &amp; Palm Beach County. Free mockup included. Mobile-first design, local SEO, and booking integrations." />
    <link rel="canonical" href="https://lambertttech.com/" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="theme-color" content="#1F4E89" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lambertt Tech LLC" />
    <meta property="og:url" content="https://lambertttech.com/" />
    <meta property="og:title" content="Websites for Local Businesses in Jupiter, FL | Lambertt Tech" />
    <meta property="og:description" content="Custom websites for local businesses in Jupiter &amp; Palm Beach County. Free mockup included. Mobile-first design, local SEO, and booking integrations." />
    <meta property="og:image" content="https://lambertttech.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lambertt Tech — Websites for Local Businesses in Jupiter, FL" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Websites for Local Businesses in Jupiter, FL | Lambertt Tech" />
    <meta name="twitter:description" content="Custom websites for local businesses in Jupiter &amp; Palm Beach County. Free mockup included." />
    <meta name="twitter:image" content="https://lambertttech.com/og-image.png" />
    <!-- Structured Data -->
    <script type="application/ld+json">{
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Lambertt Tech LLC",
      "url": "https://lambertttech.com/",
      "telephone": "+15617814836",
      "email": "angel@lambertt.tech",
      "description": "Custom web design for local businesses in Jupiter and Palm Beach County, FL.",
      "image": "https://lambertttech.com/og-image.png",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Jupiter",
        "addressRegion": "FL",
        "postalCode": "33458",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 26.9342,
        "longitude": -80.0942
      },
      "areaServed": [
        { "@type": "City", "name": "Jupiter" },
        { "@type": "City", "name": "Palm Beach Gardens" },
        { "@type": "City", "name": "Tequesta" },
        { "@type": "County", "name": "Palm Beach County" }
      ],
      "serviceType": "Web Design and Development",
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Web Design Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "One-page websites" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website refreshes" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Click-to-call and directions" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Booking integrations" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Photo and content cleanup" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Local SEO basics" } }
        ]
      }
    }</script>
    <link rel="dns-prefetch" href="https://images.pexels.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- HEADER -->
    <header
      class="sticky top-0 z-40 w-full border-b"
      style="background-color: rgba(255,255,255,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-color: var(--color-border);"
    >
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="flex h-[68px] items-center justify-between">
          <a href="#" class="flex items-center" aria-label="Lambertt Tech — home">
            <img
              src="/brand/logo-horizontal.svg"
              alt="Lambertt Tech"
              class="block h-[44px] w-auto"
            />
          </a>

          <nav class="hidden md:flex items-center gap-7" aria-label="Main navigation">
            <a
              href="#work"
              class="text-[13px] font-medium tracking-wide transition-opacity hover:opacity-70"
              style="color: var(--color-text-secondary);">Examples</a
            >
            <a
              href="#services"
              class="text-[13px] font-medium tracking-wide transition-opacity hover:opacity-70"
              style="color: var(--color-text-secondary);">Services</a
            >
            <a
              href="#pricing"
              class="text-[13px] font-medium tracking-wide transition-opacity hover:opacity-70"
              style="color: var(--color-text-secondary);">Pricing</a
            >
            <a
              href="#contact"
              class="text-[13px] font-medium tracking-wide transition-opacity hover:opacity-70"
              style="color: var(--color-text-secondary);">Contact</a
            >
            <a
              href="#contact"
              class="inline-flex items-center rounded-full px-5 py-2 text-[13px] font-semibold text-white transition-all duration-200 hover:-translate-y-px hover:shadow-md active:translate-y-0"
              style="background-color: var(--color-brand-blue); letter-spacing: 0.01em; box-shadow: 0 1px 6px 0 rgba(31,78,137,0.22);"
              >Get a free mockup</a
            >
          </nav>

          <!-- Mobile hamburger (CSS-only toggle) -->
          <div class="md:hidden relative">
            <input type="checkbox" id="nav-toggle" class="sr-only" aria-label="Toggle mobile menu" />
            <label
              for="nav-toggle"
              class="flex h-11 w-11 cursor-pointer items-center justify-center rounded-full"
              style="color: var(--color-text-primary);"
              aria-label="Open navigation menu"
            >
              <svg
                class="hamburger-open"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
                ><path
                  d="M3 5h14M3 10h14M3 15h14"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"></path></svg
              >
              <svg
                class="hamburger-close"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
                ><path
                  d="M5 5l10 10M15 5L5 15"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"></path></svg
              >
            </label>
            <div
              class="mobile-menu absolute right-0 mt-2 w-64 rounded-2xl border shadow-xl p-4"
              style="background-color: var(--color-surface); border-color: var(--color-border);"
            >
              <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
                <a href="#work" class="py-2.5 text-sm font-medium" style="color: var(--color-text-secondary);">Examples</a>
                <a href="#services" class="py-2.5 text-sm font-medium" style="color: var(--color-text-secondary);">Services</a>
                <a href="#pricing" class="py-2.5 text-sm font-medium" style="color: var(--color-text-secondary);">Pricing</a>
                <a href="#contact" class="py-2.5 text-sm font-medium" style="color: var(--color-text-secondary);">Contact</a>
                <a
                  href="#contact"
                  class="mt-3 inline-flex items-center justify-center rounded-full px-7 text-sm font-semibold text-white min-h-[48px]"
                  style="background-color: var(--color-brand-blue); box-shadow: 0 2px 12px 0 rgba(31,78,137,0.22);"
                  >Get a free mockup</a
                >
              </nav>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background-color: var(--color-background);">
      <div
        class="pointer-events-none absolute inset-0"
        style="background-image: radial-gradient(circle, var(--color-brand-blue) 1px, transparent 1px); background-size: 28px 28px; opacity: 0.04;"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -top-32 right-0 h-[600px] w-[600px] rounded-full"
        style="background: radial-gradient(circle at center, rgba(31,78,137,0.10) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl px-5 sm:px-8 pt-14 pb-16 md:pt-20 md:pb-24 lg:pt-24 lg:pb-28">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 lg:items-center">

          <!-- Left: copy -->
          <div>
            <div
              class="animate-fade-up mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold"
              style="background-color: var(--color-brand-soft); border-color: rgba(31,78,137,0.2); color: var(--color-brand-blue);"
            >
              <span class="inline-flex" set:html={ico("map-pin")} />
              Based in Jupiter, Florida
            </div>

            <h1
              class="animate-fade-up delay-100 text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-[3.25rem]"
