---
import "../styles/global.css";

const phone = ""; // TODO: Add phone number
const email = "angel@lambertt.tech";
const location = "Jupiter, Florida";

const examples = [
  {
    title: "Hair salon in Palm Beach Gardens",
    image: "/examples/salon.jpg", // TODO: Replace with actual screenshot
    liveUrl: null,
  },
  {
    title: "Café and bakery in Jupiter",
    image: "/examples/cafe.jpg", // TODO: Replace with actual screenshot
    liveUrl: null,
  },
  {
    title: "Boutique in Tequesta",
    image: "/examples/boutique.jpg", // TODO: Replace with actual screenshot
    liveUrl: null,
  },
  {
    title: "Barbershop in Stuart",
    image: "/examples/barbershop.jpg", // TODO: Replace with actual screenshot
    liveUrl: null,
  },
];

const services = [
  "One-page websites for local businesses.",
  "Refreshes of existing sites that look dated or are hard to use on a phone.",
  "Click-to-call and directions setup.",
  "Booking integrations (Setmore, Square, OpenTable).",
  "Photo and content cleanup.",
  "Local SEO basics.",
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Simple websites for local businesses in Jupiter, FL. Lambertt Tech LLC builds clean, mobile-friendly sites for salons, cafés, boutiques, and more." />
    <title>Lambertt Tech LLC — Simple Websites for Local Businesses</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[var(--color-background)] text-[var(--color-foreground)] font-sans antialiased">
    
    <!-- Hero -->
    <section class="min-h-[85vh] flex flex-col justify-center px-6 py-16 md:px-12 lg:px-24">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight tracking-tight text-balance">
          Simple websites for local businesses.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-[var(--color-muted)] leading-relaxed max-w-lg">
          I build clean, mobile-friendly sites for salons, cafés, boutiques, and other small businesses in Jupiter, FL.
        </p>
        
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a 
            href="#examples" 
            class="inline-flex items-center justify-center px-6 py-3.5 bg-[var(--color-accent)] text-white font-medium rounded-lg hover:bg-[var(--color-accent-dark)] transition-colors text-base"
          >
            See examples
          </a>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 sm:gap-8 text-[var(--color-muted)]">
          {phone && (
            <a href={`tel:${phone.replace(/[^0-9]/g, "")}`} class="hover:text-[var(--color-foreground)] transition-colors">
              {phone}
            </a>
          )}
          <a href={`mailto:${email}`} class="hover:text-[var(--color-foreground)] transition-colors">
            {email}
          </a>
        </div>
      </div>
    </section>

    <!-- Examples -->
    <section id="examples" class="px-6 py-20 md:px-12 lg:px-24 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
          Recent work
        </h2>
        <p class="mt-3 text-[var(--color-muted)] text-lg">
          A few examples of sites I have built for local businesses.
        </p>

        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-8">
          {examples.map((example) => (
            <div class="group">
              <div class="aspect-[4/3] bg-[var(--color-border)] rounded-lg overflow-hidden">
                {/* TODO: Replace placeholder with actual screenshot */}
                <div class="w-full h-full flex items-center justify-center text-[var(--color-muted)] text-sm">
                  Placeholder image
                </div>
              </div>
              <p class="mt-4 text-[var(--color-foreground)] font-medium">
                {example.title}
              </p>
              {example.liveUrl && (
                <a 
                  href={example.liveUrl} 
                  class="mt-1 inline-block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-dark)] transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  View live →
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="px-6 py-20 md:px-12 lg:px-24">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
          What I do
        </h2>
        
        <ul class="mt-10 space-y-5">
          {services.map((service) => (
            <li class="flex gap-4 text-lg leading-relaxed">
              <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13.5 4.5L6.5 11.5L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{service}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Pricing & Contact -->
    <section class="px-6 py-20 md:px-12 lg:px-24 bg-white">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
          Pricing
        </h2>
        <p class="mt-6 text-lg text-[var(--color-muted)] leading-relaxed">
          Most one-page sites run between $500 and $1,500 depending on complexity. Refreshes of existing sites start around $300. I am happy to give you a quick estimate after seeing what you need.
        </p>
        
        <div class="mt-12 p-8 bg-[var(--color-background)] rounded-xl border border-[var(--color-border)]">
          <h3 class="text-xl font-semibold">
            Get a free mockup
          </h3>
          <p class="mt-3 text-[var(--color-muted)] leading-relaxed">
            I will put together a free one-page mockup so you can see what your site would look like before deciding anything.
          </p>
          
          <div class="mt-8 space-y-4">
            <a 
              href={`mailto:${email}`}
              class="flex items-center gap-3 text-[var(--color-foreground)] hover:text-[var(--color-accent)] transition-colors"
            >
              <svg class="w-5 h-5 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <span>{email}</span>
            </a>
            
            {phone && (
              <a 
                href={`tel:${phone.replace(/[^0-9]/g, "")}`}
                class="flex items-center gap-3 text-[var(--color-foreground)] hover:text-[var(--color-accent)] transition-colors"
              >
                <svg class="w-5 h-5 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <span>{phone}</span>
              </a>
            )}
            
            <p class="flex items-center gap-3 text-[var(--color-muted)]">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <span>Based in {location}. Happy to meet in person.</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-12 md:px-12 lg:px-24 border-t border-[var(--color-border)]">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="text-sm text-[var(--color-muted)]">
          <span class="text-[var(--color-foreground)] font-medium">Lambertt Tech LLC</span>
          <span class="mx-2">·</span>
          <span>© {new Date().getFullYear()}</span>
        </div>
        <a 
          href="https://alambertt.dev" 
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Engineering portfolio →
        </a>
      </div>
    </footer>

  </body>
</html>
