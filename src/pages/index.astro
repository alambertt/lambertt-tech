    <!-- HERO CAROUSEL SCRIPT -->
    <script is:inline>
    (function () {
      const PHONE_SM = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>';
      const MAP_PIN_SM = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>';

      const SLIDES = [
        {
          name: 'Coastal Café',
          slug: 'coastalcafe.com',
          meta: 'Jupiter, FL · Open until 9 pm',
          chips: ['Menu', 'Hours', 'Contact'],
          cta: 'Order now',
          footerCta: 'Get directions',
          img: 'https://images.pexels.com/photos/1813504/pexels-photo-1813504.jpeg?auto=compress&cs=tinysrgb&w=960&h=540&fit=crop',
          imgAlt: 'Warm, candlelit café interior with wood tables',
        },
        {
          name: 'Palm Beauty Studio',
          slug: 'palmbeautystudio.com',
          meta: 'Jupiter, FL · Appointments available',
          chips: ['Services', 'Stylists', 'Reviews'],
          cta: 'Book now',
          footerCta: 'View hours',
          img: 'https://images.pexels.com/photos/3993449/pexels-photo-3993449.jpeg?auto=compress&cs=tinysrgb&w=960&h=540&fit=crop',
          imgAlt: 'Elegant hair and beauty studio with a stylist at work',
        },
        {
          name: 'BlueWave Home Services',
          slug: 'bluewavehome.com',
          meta: 'Palm Beach County · Same-week service',
          chips: ['Services', 'Areas', 'Reviews'],
          cta: 'Request quote',
          footerCta: 'Service areas',
          img: 'https://images.pexels.com/photos/4108714/pexels-photo-4108714.jpeg?auto=compress&cs=tinysrgb&w=960&h=540&fit=crop',
          imgAlt: 'Modern Florida home exterior with manicured landscaping',
          imgFallback: 'https://images.pexels.com/photos/2102587/pexels-photo-2102587.jpeg?auto=compress&cs=tinysrgb&w=960&h=540&fit=crop',
        },
        {
          name: 'Shoreline Boutique',
          slug: 'shorelineboutique.com',
          meta: 'Jupiter, FL · New arrivals',
          chips: ['Shop', 'Lookbook', 'Visit'],
          cta: 'Shop now',
          footerCta: 'Visit store',
          img: 'https://images.pexels.com/photos/3965545/pexels-photo-3965545.jpeg?auto=compress&cs=tinysrgb&w=960&h=540&fit=crop',
          imgAlt: 'Curated boutique clothing rack with elegant neutral tones',
        },
      ];

      const stageEl = document.getElementById('carousel-stage');
      const dotsEl  = document.getElementById('carousel-dots');
      const urlEl   = document.getElementById('carousel-url');
      const wrapEl  = document.getElementById('hero-carousel');

      if (!stageEl || !dotsEl || !urlEl || !wrapEl) return;

      stageEl.innerHTML = SLIDES.map((s, i) => `
        <article class="carousel-slide ${i === 0 ? 'is-active' : ''}" role="tabpanel"
                 aria-roledescription="slide" aria-label="${i + 1} of ${SLIDES.length}: ${s.name}"
                 ${i !== 0 ? 'aria-hidden="true"' : ''}>
          <div class="relative overflow-hidden" style="height: 220px;">
            <img
              src="${s.img}"
              alt="${s.imgAlt}"
              class="carousel-slide-image absolute inset-0 h-full w-full object-cover"
              loading="${i === 0 ? 'eager' : 'lazy'}"
              decoding="async"
              ${s.imgFallback ? `onerror="this.onerror=null;this.src='${s.imgFallback}';"` : ''}
            />
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(11,42,61,0.05) 0%, rgba(11,42,61,0.65) 100%);" aria-hidden="true"></div>
            <div class="absolute bottom-0 left-0 right-0 px-5 py-4">
              <p class="text-base font-bold text-white leading-tight">${s.name}</p>
              <p class="text-xs mt-0.5" style="color: rgba(255,255,255,0.85);">${s.meta}</p>
            </div>
          </div>
          <div class="px-5 py-4 space-y-3">
            <div class="flex items-center justify-between gap-2" aria-hidden="true">
              <div class="flex gap-2">
                ${s.chips.map(c => `<div class="rounded-full px-2.5 py-1 text-xs font-medium" style="background-color: var(--color-brand-soft); color: var(--color-brand-blue);">${c}</div>`).join('')}
              </div>
              <div class="rounded-full px-3 py-1.5 text-xs font-semibold text-white whitespace-nowrap" style="background-color: var(--color-brand-blue);">${s.cta}</div>
            </div>
            <div class="space-y-2" aria-hidden="true">
              <div class="flex gap-2 items-center"><div class="h-2.5 w-2.5 rounded-full shrink-0" style="background-color: var(--color-accent-teal);"></div><div class="h-2 w-32 rounded-full" style="background-color: var(--color-brand-soft);"></div></div>
              <div class="flex gap-2 items-center"><div class="h-2.5 w-2.5 rounded-full shrink-0" style="background-color: var(--color-accent-teal);"></div><div class="h-2 w-40 rounded-full" style="background-color: var(--color-brand-soft);"></div></div>
              <div class="flex gap-2 items-center"><div class="h-2.5 w-2.5 rounded-full shrink-0" style="background-color: var(--color-accent-teal);"></div><div class="h-2 w-28 rounded-full" style="background-color: var(--color-brand-soft);"></div></div>
            </div>
          </div>
          <div class="flex items-center justify-between px-5 py-3 border-t" style="border-color: var(--color-border); background-color: #F8FAFC;" aria-hidden="true">
            <div class="flex items-center gap-1.5"><span style="color: var(--color-brand-blue);">${PHONE_SM}</span><div class="h-2 w-20 rounded-full" style="background-color: var(--color-brand-soft);"></div></div>
            <div class="flex items-center gap-1.5"><span style="color: var(--color-brand-blue);">${MAP_PIN_SM}</span><div class="h-2 w-16 rounded-full" style="background-color: var(--color-brand-soft);"></div></div>
            <div class="rounded-full px-3 py-1 text-[10px] font-semibold text-white whitespace-nowrap" style="background-color: var(--color-brand-blue);">${s.footerCta}</div>
          </div>
        </article>
      `).join('');

      dotsEl.innerHTML = SLIDES.map((s, i) => `
        <button class="carousel-dot ${i === 0 ? 'is-active' : ''}" type="button"
                role="tab" data-index="${i}"
                aria-label="Show ${s.name}"
                aria-selected="${i === 0 ? 'true' : 'false'}"></button>
      `).join('');

      const slideEls = stageEl.querySelectorAll('.carousel-slide');
      const dotBtns  = dotsEl.querySelectorAll('.carousel-dot');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const ROTATE_MS = 5500;
      let current = 0;
      let timer = null;

      function goTo(i) {
        current = ((i % SLIDES.length) + SLIDES.length) % SLIDES.length;
        slideEls.forEach((el, idx) => {
          const active = idx === current;
          el.classList.toggle('is-active', active);
          el.setAttribute('aria-hidden', active ? 'false' : 'true');
        });
        dotBtns.forEach((el, idx) => {
          const active = idx === current;
          el.classList.toggle('is-active', active);
          el.setAttribute('aria-selected', String(active));
        });
        urlEl.style.opacity = '0';
        setTimeout(() => {
          urlEl.textContent = SLIDES[current].slug;
          urlEl.style.opacity = '1';
        }, 200);
      }

      function start() {
        if (reducedMotion) return;
        stop();
        timer = setInterval(() => goTo(current + 1), ROTATE_MS);
      }
      function stop() {
        if (timer) { clearInterval(timer); timer = null; }
      }

      dotsEl.addEventListener('click', e => {
        const btn = e.target.closest('.carousel-dot');
        if (!btn) return;
        goTo(parseInt(btn.dataset.index, 10));
        start();
      });

      wrapEl.addEventListener('mouseenter', stop);
      wrapEl.addEventListener('mouseleave', start);
      wrapEl.addEventListener('focusin', stop);
      wrapEl.addEventListener('focusout', start);
      wrapEl.addEventListener('touchstart', stop, { passive: true });
      wrapEl.addEventListener('touchend', () => setTimeout(start, 2500), { passive: true });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop(); else start();
      });

      wrapEl.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); start(); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(current - 1); start(); }
      });

      start();
    })();
    </script>

    <Analytics />
  </body>
</html>
